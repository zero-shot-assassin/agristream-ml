# Core environment
ENVIRONMENT=local
AWS_REGION=us-east-1

# S3
AGRISTREAM_S3_BUCKET=agristream-ml-dev-bucket

# SQS
AGRISTREAM_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/agristream-ml-dev-queue

# Local dev credentials (use IAM roles in real AWS!)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY